{
  "name": "@pxs/core",
  "version": "4.0.0",
  "description": "PXS Core - Headless pixel cell animation library",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./wasm": {
      "types": "./dist/wasm/WASMIntegration.d.ts",
      "import": "./dist/wasm/WASMIntegration.mjs",
      "require": "./dist/wasm/WASMIntegration.js"
    }
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "pixel-art",
    "animation",
    "canvas",
    "webgl",
    "cell-animation",
    "graphics",
    "wasm"
  ],
  "author": "Brian Bellissimo",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.7.0"
  }
}
