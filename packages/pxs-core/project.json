{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "pxs-core",
  "sourceRoot": "packages/pxs-core/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vite build",
        "cwd": "packages/pxs-core"
      },
      "outputs": ["{projectRoot}/dist"]
    },
    "type-check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit",
        "cwd": "packages/pxs-core"
      }
    }
  },
  "tags": ["type:library"]
}
