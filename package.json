{
  "name": "@pxs/workspace",
  "version": "4.0.0",
  "private": true,
  "description": "PXS - Pixel Cell Animation Platform (Monorepo)",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "nx run-many --target=dev --all",
    "build": "nx run-many --target=build --all",
    "core:build": "nx run pxs-core:build",
    "studio:dev": "nx run pxs-studio:dev",
    "studio:build": "nx run pxs-studio:build",
    "lint": "nx run-many --target=lint --all",
    "test": "nx run-many --target=test --all",
    "wasm:build": "cd wasm && ./build.sh"
  },
  "devDependencies": {
    "nx": "^18.0.0",
    "@nx/js": "^18.0.0",
    "@nx/vite": "^18.0.0",
    "@nx/next": "^18.0.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
